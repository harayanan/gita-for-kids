---
interface ChapterMeta {
  slug: string;
  name: string;
  sanskrit_name: string;
  number: number;
  status?: string;
}

interface Props {
  chapters: ChapterMeta[];
  currentChapter: number;
}

const { chapters, currentChapter } = Astro.props;

// Only link to active chapters to avoid 404s
const activeChapters = chapters.filter((c) => !c.status || c.status === 'active');
const sortedActive = activeChapters.sort((a, b) => a.number - b.number);
const currentIndex = sortedActive.findIndex((c) => c.number === currentChapter);
const prev = currentIndex > 0 ? sortedActive[currentIndex - 1] : undefined;
const next = currentIndex < sortedActive.length - 1 ? sortedActive[currentIndex + 1] : undefined;
---

<nav class="max-w-reading mx-auto px-4 py-8 flex items-center justify-between font-ui text-sm border-t border-gold/20 mt-12">
  {prev ? (
    <a
      href={`/chapters/${prev.slug}`}
      class="flex flex-col items-start text-saffron hover:text-saffron/80 transition-colors"
    >
      <span class="text-xs text-gray-400">&larr; Previous</span>
      <span class="font-medium">Ch {prev.number}: {prev.name}</span>
    </a>
  ) : (
    <span></span>
  )}

  <a href="/" class="text-gray-500 hover:text-saffron transition-colors">Home</a>

  {next ? (
    <a
      href={`/chapters/${next.slug}`}
      class="flex flex-col items-end text-saffron hover:text-saffron/80 transition-colors"
    >
      <span class="text-xs text-gray-400">Next &rarr;</span>
      <span class="font-medium">Ch {next.number}: {next.name}</span>
    </a>
  ) : (
    <span></span>
  )}
</nav>
