---
import Tooltip from './Tooltip.tsx';

interface Props {
  title: string;
  source: string;
  body: string;
  glossary: { term: string; definition: string }[];
}

const { title, source, body, glossary } = Astro.props;

const sourceLabel = source === 'original' ? 'An original story' : `From the ${source}`;
---

<div class="bg-terracotta/8 rounded-xl px-6 py-8 my-6 border border-terracotta/15">
  <div class="flex items-baseline justify-between mb-4">
    <h3 class="font-body text-xl font-semibold text-terracotta">{title}</h3>
    <span class="font-ui text-xs text-terracotta/60 italic">{sourceLabel}</span>
  </div>
  <div class="font-body text-base leading-relaxed text-gray-800 space-y-4">
    {body.split('\n\n').map((paragraph) => (
      <p>
        <Tooltip client:load glossary={glossary} text={paragraph} />
      </p>
    ))}
  </div>
</div>
