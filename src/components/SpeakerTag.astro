---
interface Props {
  speaker: string;
}

const { speaker } = Astro.props;

const speakerInfo: Record<string, { label: string; color: string; icon: string }> = {
  dhritarashtra: { label: 'Dhritarashtra speaks', color: 'text-gray-600 bg-gray-100', icon: '👑' },
  sanjaya: { label: 'Sanjaya narrates', color: 'text-indigo bg-indigo/10', icon: '👁' },
  duryodhana: { label: 'Duryodhana speaks', color: 'text-gray-700 bg-amber-100', icon: '⚔️' },
  arjuna: { label: 'Arjuna speaks', color: 'text-terracotta bg-terracotta/10', icon: '🏹' },
  krishna: { label: 'Krishna speaks', color: 'text-forest bg-forest/10', icon: '🪈' },
};

const info = speakerInfo[speaker] || { label: speaker, color: 'text-gray-600 bg-gray-100', icon: '💬' };
---

<div class={`inline-flex items-center gap-2 px-3 py-1 rounded-full font-ui text-xs font-medium ${info.color}`}>
  <span>{info.icon}</span>
  <span>{info.label}</span>
</div>
