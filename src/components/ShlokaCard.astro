---
import FolkArtBorder from './FolkArtBorder.astro';
import SanskritText from './SanskritText.astro';
import DhatuBreakdown from './DhatuBreakdown.astro';
import StoryBlock from './StoryBlock.astro';
import SpeakerTag from './SpeakerTag.astro';
import Tooltip from './Tooltip.tsx';

interface DhatuEntry {
  word: string;
  parts: string[];
  meaning: string;
}

interface Story {
  title: string;
  source: string;
  body: string;
}

interface Props {
  chapter: number;
  verse: number;
  speaker: string;
  sanskrit: string;
  transliteration: string;
  dhatu_breakdown: DhatuEntry[];
  meaning: string;
  story: Story;
  reflection: string;
  illustration?: string;
  illustrationAlt?: string;
  glossary: { term: string; definition: string }[];
  folkArtStyle?: 'madhubani' | 'pichwai' | 'pattachitra' | 'warli' | 'kalamkari' | 'gond';
}

const {
  chapter,
  verse,
  speaker,
  sanskrit,
  transliteration,
  dhatu_breakdown,
  meaning,
  story,
  reflection,
  illustration,
  illustrationAlt,
  glossary,
  folkArtStyle = 'madhubani',
} = Astro.props;
---

<article class="max-w-reading mx-auto px-4 py-12" data-speaker={speaker}>
  <!-- 1. Chapter & Verse Number -->
  <div class="text-center mb-8">
    <span class="font-ui text-xs font-semibold uppercase tracking-widest text-gold" transition:name={`verse-${chapter}-${verse}`}>
      Chapter {chapter} &middot; Verse {verse}
    </span>
  </div>

  <!-- Speaker -->
  <div class="flex justify-center mb-6">
    <SpeakerTag speaker={speaker} />
  </div>

  <!-- 2. Illustration -->
  {illustration && (
    <div class="-mx-4 sm:-mx-8 md:-mx-16 mb-10 scroll-reveal">
      <img
        src={illustration}
        alt={illustrationAlt || `Illustration for Chapter ${chapter}, Verse ${verse}`}
        class="w-full"
        loading="lazy"
        transition:name={`illustration-${chapter}-${verse}`}
      />
    </div>
  )}

  <!-- 3 & 4. Sanskrit + Transliteration -->
  <div class="mb-8 scroll-reveal" style="transition-delay: 0.1s">
    <SanskritText sanskrit={sanskrit} transliteration={transliteration} />
  </div>

  <!-- 5. Dhatu Breakdown -->
  <div class="scroll-reveal" style="transition-delay: 0.2s">
    <DhatuBreakdown breakdown={dhatu_breakdown} />
  </div>

  <!-- Divider -->
  <div class="flex items-center gap-4 my-8 scroll-reveal" style="transition-delay: 0.25s">
    <div class="flex-1 h-px bg-gold/20"></div>
    <span lang="sa" class="font-devanagari text-gold/40 text-lg" aria-hidden="true">॥</span>
    <div class="flex-1 h-px bg-gold/20"></div>
  </div>

  <!-- 6. Simple Meaning -->
  <div class="py-6 scroll-reveal" style="transition-delay: 0.3s">
    <FolkArtBorder style={folkArtStyle}>
      <div class="border-l-[3px] border-gold/40 pl-6">
        <p class="font-body text-xl md:text-2xl leading-relaxed text-gray-800">
          <Tooltip client:load glossary={glossary} text={meaning} />
        </p>
      </div>
    </FolkArtBorder>
  </div>

  <!-- 7. The Story -->
  <div class="scroll-reveal" style="transition-delay: 0.4s">
    <StoryBlock
      title={story.title}
      source={story.source}
      body={story.body}
      glossary={glossary}
    />
  </div>

  <!-- 8. Reflection -->
  <div class="text-center py-10 my-6 scroll-reveal" style="transition-delay: 0.6s">
    <span lang="sa" class="font-devanagari text-forest/30 text-sm block mb-4">चिन्तनम्</span>
    <p class="font-body text-xl md:text-2xl italic text-gray-700 leading-relaxed max-w-lg mx-auto">
      {reflection}
    </p>
  </div>
</article>
