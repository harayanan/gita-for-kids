---
import BaseLayout from './BaseLayout.astro';

interface Props {
  chapterNumber: number;
  chapterName: string;
  sanskritName: string;
  summary: string;
}

const { chapterNumber, chapterName, sanskritName, summary } = Astro.props;
---

<BaseLayout title={`Chapter ${chapterNumber}: ${chapterName} — Gita for Kids`}>
  <div class="max-w-reading mx-auto px-4 py-12">
    <!-- Chapter Header -->
    <header class="text-center mb-12">
      <span class="font-ui text-xs font-semibold uppercase tracking-widest text-gold">
        Chapter {chapterNumber}
      </span>
      <h1 class="font-body text-3xl md:text-4xl font-bold text-gray-900 mt-3 mb-2">
        {chapterName}
      </h1>
      <p class="font-devanagari text-xl text-saffron/70">
        {sanskritName}
      </p>
      <p class="font-body text-base text-gray-600 mt-4 max-w-lg mx-auto leading-relaxed">
        {summary}
      </p>
    </header>

    <slot />
  </div>
</BaseLayout>
